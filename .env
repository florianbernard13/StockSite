# -----------------------------
# Flask App
# -----------------------------
FLASK_APP=app.py
FLASK_RUN_HOST=0.0.0.0
FLASK_ENV=development
FLASK_DEBUG=1
VITE_ENV=development
APP_PORT=5000
VITE_PORT=5173

# -----------------------------
# Database principale (TimescaleDB / Stock)
# -----------------------------
STOCK_DB_USER=stock
STOCK_DB_PASSWORD=stock
STOCK_DB_PORT=5432       # dans le container, mapé depuis 5433 sur la machine
STOCK_DB_NAME=stock

# -----------------------------
# Database SonarQube
# -----------------------------
SONAR_DB_USER=sonar
SONAR_DB_PASSWORD=sonar
SONAR_DB_NAME=sonardb

# -----------------------------
# SonarQube
# -----------------------------
SONARQUBE_JDBC_URL=jdbc:postgresql://sonardb:5432/sonar
SONARQUBE_JDBC_USERNAME=sonar
SONARQUBE_JDBC_PASSWORD=sonar